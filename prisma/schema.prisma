generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  userId    Int      @id @default(autoincrement()) @map("user_id")
  name      String
  email     String
  password  String
  phone     String?
  role      String   @db.VarChar(20)
  status    String   @default("active") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("users")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model audit_logs {
  id            BigInt    @id @default(autoincrement())
  branch_id     String?   @db.Uuid
  actor_user_id String?   @db.Uuid
  action        String    @db.VarChar(128)
  entity_type   String?   @db.VarChar(64)
  entity_id     String?   @db.Uuid
  metadata      Json      @default("{}")
  ip_address    String?   @db.Inet
  user_agent    String?
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  branches      branches? @relation(fields: [branch_id], references: [id], onUpdate: NoAction)

  @@index([actor_user_id], map: "idx_audit_actor")
  @@index([created_at(sort: Desc)], map: "idx_audit_created")
  @@index([entity_type, entity_id], map: "idx_audit_entity")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model branches {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String             @db.VarChar(255)
  code             String?            @unique @db.VarChar(64)
  address          String?
  phone            String?            @db.VarChar(50)
  timezone         String             @default("UTC") @db.VarChar(64)
  is_active        Boolean            @default(true)
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @default(now()) @db.Timestamptz(6)
  audit_logs       audit_logs[]
  notifications    notifications[]
  patients         patients[]
  queue_entries    queue_entries[]
  therapy_sessions therapy_sessions[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model notifications {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branch_id            String?   @db.Uuid
  recipient_user_id    String?   @db.Uuid
  recipient_patient_id String?   @db.Uuid
  channel              String    @default("in_app") @db.VarChar(32)
  subject              String?   @db.VarChar(500)
  body                 String?
  payload              Json      @default("{}")
  read_at              DateTime? @db.Timestamptz(6)
  created_at           DateTime  @default(now()) @db.Timestamptz(6)
  branches             branches? @relation(fields: [branch_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  patients             patients? @relation(fields: [recipient_patient_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_notifications_created")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model patients {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branch_id         String             @db.Uuid
  medical_record_no String?            @db.VarChar(64)
  first_name        String             @db.VarChar(120)
  last_name         String             @db.VarChar(120)
  date_of_birth     DateTime?          @db.Date
  phone             String?            @db.VarChar(50)
  email             String?            @db.VarChar(320)
  notes             String?
  is_active         Boolean            @default(true)
  created_at        DateTime           @default(now()) @db.Timestamptz(6)
  updated_at        DateTime           @default(now()) @db.Timestamptz(6)
  notifications     notifications[]
  branches          branches           @relation(fields: [branch_id], references: [id], onUpdate: NoAction)
  queue_entries     queue_entries[]
  therapy_sessions  therapy_sessions[]

  @@unique([branch_id, medical_record_no], map: "uq_patients_branch_mrn")
  @@index([branch_id], map: "idx_patients_branch")
  @@index([branch_id, last_name, first_name], map: "idx_patients_name")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model queue_entries {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branch_id        String            @db.Uuid
  patient_id       String            @db.Uuid
  priority         Int               @default(0)
  status           String            @default("waiting") @db.VarChar(32)
  session_id       String?           @db.Uuid
  queued_at        DateTime          @default(now()) @db.Timestamptz(6)
  called_at        DateTime?         @db.Timestamptz(6)
  notes            String?           @db.VarChar(500)
  branches         branches          @relation(fields: [branch_id], references: [id], onUpdate: NoAction)
  patients         patients          @relation(fields: [patient_id], references: [id], onUpdate: NoAction)
  therapy_sessions therapy_sessions? @relation(fields: [session_id], references: [id], onUpdate: NoAction)

  @@index([branch_id, status], map: "idx_queue_branch_status")
  @@index([branch_id, queued_at], map: "idx_queue_queued_at")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model system_settings {
  key                String   @id @db.VarChar(128)
  value              Json
  updated_at         DateTime @default(now()) @db.Timestamptz(6)
  updated_by_user_id String?  @db.Uuid
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model therapy_sessions {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branch_id         String          @db.Uuid
  patient_id        String          @db.Uuid
  therapist_user_id String          @db.Uuid
  scheduled_start   DateTime        @db.Timestamptz(6)
  scheduled_end     DateTime?       @db.Timestamptz(6)
  status            String          @default("scheduled") @db.VarChar(32)
  room_label        String?         @db.VarChar(64)
  notes             String?
  created_at        DateTime        @default(now()) @db.Timestamptz(6)
  updated_at        DateTime        @default(now()) @db.Timestamptz(6)
  queue_entries     queue_entries[]
  branches          branches        @relation(fields: [branch_id], references: [id], onUpdate: NoAction)
  patients          patients        @relation(fields: [patient_id], references: [id], onUpdate: NoAction)

  @@index([branch_id, scheduled_start], map: "idx_sessions_branch_time")
  @@index([patient_id], map: "idx_sessions_patient")
  @@index([branch_id, status], map: "idx_sessions_status")
  @@index([therapist_user_id], map: "idx_sessions_therapist")
}

enum app_role {
  SUPER_ADMIN
  ADMIN
  THERAPIST
}
