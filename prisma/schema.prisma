generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  userId    Int      @id @default(autoincrement()) @map("user_id")
  name      String
  email     String
  password  String
  phone     String?
  role      String   @db.VarChar(20)
  status    String   @default("active") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("users")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model audit_logs {
  id            BigInt    @id @default(autoincrement())
  branch_id     String?   @db.Uuid
  actor_user_id String?   @db.Uuid
  action        String    @db.VarChar(128)
  entity_type   String?   @db.VarChar(64)
  entity_id     String?   @db.Uuid
  metadata      Json      @default("{}")
  ip_address    String?   @db.Inet
  user_agent    String?
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  branches      branches? @relation(fields: [branch_id], references: [id], onUpdate: NoAction)

  @@index([actor_user_id], map: "idx_audit_actor")
  @@index([created_at(sort: Desc)], map: "idx_audit_created")
  @@index([entity_type, entity_id], map: "idx_audit_entity")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model branches {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String             @db.VarChar(255)
  code             String?            @unique @db.VarChar(64)
  address          String?
  phone            String?            @db.VarChar(50)
  timezone         String             @default("UTC") @db.VarChar(64)
  is_active        Boolean            @default(true)
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @default(now()) @db.Timestamptz(6)
  audit_logs       audit_logs[]
  notifications    notifications[]
  patients                  patients[]
  queue_entries             queue_entries[]
  therapy_sessions          therapy_sessions[]
  rehabilitation_records    rehabilitation_records[]
  therapists                therapists[]
  guardians                 guardians[]
  branch_holidays           branch_holidays[]
  wa_notification_logs      wa_notification_logs[]
}

/// Hari libur cabang (tampilan kalender sesi)
model branch_holidays {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branch_id    String    @db.Uuid
  holiday_date DateTime  @db.Date
  name         String    @db.VarChar(200)
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  branches     branches  @relation(fields: [branch_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([branch_id, holiday_date(sort: Asc)], map: "idx_branch_holidays_branch_date")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model notifications {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branch_id            String?   @db.Uuid
  recipient_user_id    String?   @db.Uuid
  recipient_patient_id String?   @db.Uuid
  channel              String    @default("in_app") @db.VarChar(32)
  subject              String?   @db.VarChar(500)
  body                 String?
  payload              Json      @default("{}")
  read_at              DateTime? @db.Timestamptz(6)
  created_at           DateTime  @default(now()) @db.Timestamptz(6)
  branches             branches? @relation(fields: [branch_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  patients             patients? @relation(fields: [recipient_patient_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_notifications_created")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model patients {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branch_id         String             @db.Uuid
  medical_record_no String?            @db.VarChar(64)
  first_name        String             @db.VarChar(120)
  last_name         String             @db.VarChar(120)
  date_of_birth     DateTime?          @db.Date
  phone             String?            @db.VarChar(50)
  email             String?            @db.VarChar(320)
  /// e.g. FISIK, MOTORIK, INTELEKTUAL — used on admin dashboard charts
  disability_type   String?            @db.VarChar(64)
  /// Alamat singkat untuk tampilan daftar pasien
  address                  String?
  /// Skor Barthel Index 0–100 (opsional)
  barthel_score            Int?
  /// BPJS | SUBSIDI | UMUM | GRATIS — untuk laporan kategori pembayaran
  payment_category         String?            @db.VarChar(32)
  /// Diagnosa utama (teks bebas) — untuk grafik diagnosa terbanyak
  primary_diagnosis        String?            @db.VarChar(200)
  /// Nama terapis utama untuk tampilan daftar (denormalisasi hingga integrasi akun)
  primary_therapist_name   String?            @db.VarChar(200)
  notes             String?
  is_active         Boolean            @default(true)
  created_at        DateTime           @default(now()) @db.Timestamptz(6)
  updated_at        DateTime           @default(now()) @db.Timestamptz(6)
  notifications     notifications[]
  branches          branches           @relation(fields: [branch_id], references: [id], onUpdate: NoAction)
  queue_entries             queue_entries[]
  therapy_sessions          therapy_sessions[]
  rehabilitation_records    rehabilitation_records[]
  guardian_patients           guardian_patients[]

  @@unique([branch_id, medical_record_no], map: "uq_patients_branch_mrn")
  @@index([branch_id], map: "idx_patients_branch")
  @@index([branch_id, last_name, first_name], map: "idx_patients_name")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model queue_entries {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branch_id        String            @db.Uuid
  patient_id       String            @db.Uuid
  priority         Int               @default(0)
  status           String            @default("waiting") @db.VarChar(32)
  session_id       String?           @db.Uuid
  queued_at        DateTime          @default(now()) @db.Timestamptz(6)
  called_at        DateTime?         @db.Timestamptz(6)
  notes            String?           @db.VarChar(500)
  branches         branches          @relation(fields: [branch_id], references: [id], onUpdate: NoAction)
  patients         patients          @relation(fields: [patient_id], references: [id], onUpdate: NoAction)
  therapy_sessions therapy_sessions? @relation(fields: [session_id], references: [id], onUpdate: NoAction)

  @@index([branch_id, status], map: "idx_queue_branch_status")
  @@index([branch_id, queued_at], map: "idx_queue_queued_at")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model system_settings {
  key                String   @id @db.VarChar(128)
  value              Json
  updated_at         DateTime @default(now()) @db.Timestamptz(6)
  updated_by_user_id String?  @db.Uuid
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model therapy_sessions {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branch_id         String          @db.Uuid
  patient_id        String          @db.Uuid
  therapist_user_id String          @db.Uuid
  scheduled_start   DateTime        @db.Timestamptz(6)
  scheduled_end     DateTime?       @db.Timestamptz(6)
  status            String          @default("scheduled") @db.VarChar(32)
  room_label        String?         @db.VarChar(64)
  notes             String?
  created_at        DateTime        @default(now()) @db.Timestamptz(6)
  updated_at        DateTime        @default(now()) @db.Timestamptz(6)
  queue_entries     queue_entries[]
  branches          branches        @relation(fields: [branch_id], references: [id], onUpdate: NoAction)
  patients          patients        @relation(fields: [patient_id], references: [id], onUpdate: NoAction)

  @@index([branch_id, scheduled_start], map: "idx_sessions_branch_time")
  @@index([patient_id], map: "idx_sessions_patient")
  @@index([branch_id, status], map: "idx_sessions_status")
  @@index([therapist_user_id], map: "idx_sessions_therapist")
}

/// Catatan rekam rehabilitasi per sesi / kunjungan
model rehabilitation_records {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branch_id        String    @db.Uuid
  patient_id       String    @db.Uuid
  session_number   Int       @default(1)
  record_date      DateTime  @db.Date
  therapist_name   String?   @db.VarChar(200)
  complaints       String?
  program_therapy  String?
  assessment       String?   @db.VarChar(120)
  motorik_adl      String?   @db.VarChar(160)
  note_clinical    String?
  note_progress    String?
  is_active        Boolean   @default(true)
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  patients         patients  @relation(fields: [patient_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  branches         branches  @relation(fields: [branch_id], references: [id], onUpdate: NoAction)

  @@index([branch_id, record_date(sort: Desc)], map: "rehabilitation_records_branch_record_idx")
  @@index([patient_id, record_date(sort: Desc)], map: "rehabilitation_records_patient_record_idx")
}

/// Profil terapis untuk tampilan admin (jadwal & ringkasan pasien)
model therapists {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branch_id        String   @db.Uuid
  display_name     String   @db.VarChar(200)
  specialization   String   @db.VarChar(120)
  schedule_days    String   @db.VarChar(240)
  schedule_hours   String   @db.VarChar(120)
  branch_label     String   @default("Pusat") @db.VarChar(80)
  total_patients   Int      @default(0)
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @updatedAt @db.Timestamptz(6)
  branches         branches @relation(fields: [branch_id], references: [id], onUpdate: NoAction)

  @@index([branch_id], map: "idx_therapists_branch")
}

/// Wali pasien (akses portal / notifikasi)
model guardians {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branch_id          String               @db.Uuid
  full_name          String               @db.VarChar(200)
  email              String               @db.VarChar(320)
  phone              String               @db.VarChar(50)
  relationship       String               @db.VarChar(40)
  last_login_at      DateTime?            @db.Timestamptz(6)
  is_active          Boolean              @default(true)
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  updated_at         DateTime             @updatedAt @db.Timestamptz(6)
  branches           branches             @relation(fields: [branch_id], references: [id], onUpdate: NoAction)
  guardian_patients  guardian_patients[]
  wa_notification_logs wa_notification_logs[]

  @@unique([branch_id, email], map: "uq_guardian_branch_email")
  @@index([branch_id], map: "idx_guardians_branch")
}

model guardian_patients {
  guardian_id String    @db.Uuid
  patient_id  String    @db.Uuid
  guardians   guardians @relation(fields: [guardian_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  patients    patients  @relation(fields: [patient_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([guardian_id, patient_id])
}

/// Log pengiriman notifikasi WhatsApp (buka wa.me dari admin)
model wa_notification_logs {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branch_id        String    @db.Uuid
  guardian_id      String?   @db.Uuid
  recipient_name   String    @db.VarChar(200)
  recipient_phone  String    @db.VarChar(50)
  template_key     String    @db.VarChar(64)
  message_body     String
  status           String    @default("terkirim") @db.VarChar(32)
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  branches         branches  @relation(fields: [branch_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  guardians        guardians? @relation(fields: [guardian_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([branch_id, created_at(sort: Desc)], map: "idx_wa_logs_branch_created")
}

enum app_role {
  SUPER_ADMIN
  ADMIN
  THERAPIST
}
