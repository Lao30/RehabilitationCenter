# Copy this file to `.env.local` and fill in real values.
# Next.js loads `.env.local` automatically (do not commit it).

# --- Auth (JWT for sessions) ---
# Use a long random string in production, e.g. `openssl rand -base64 32`
JWT_SECRET=

# --- PostgreSQL ---
# Single URL (recommended for app + Prisma + most ORMs)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Prisma reads this URL (see prisma/schema.sql). Apply db/schema.sql or: npm run db:push
#
# If you see: password authentication failed for user "postgres" (code 28P01)
# → The PASSWORD above must match your PostgreSQL server user (not the app login).
# → Special characters in the DB password must be URL-encoded in this string (@ %2F # %23 etc.).
# → Test: psql "postgresql://postgres:YOUR_PASSWORD@localhost:5432/rcms" -c "SELECT 1"
DATABASE_URL=postgresql://postgres:12345@localhost:5432/rcms

# Optional: SSL when connecting to cloud Postgres (Neon, RDS, Supabase, etc.)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Optional: discrete variables (if you use tooling that reads these instead of DATABASE_URL)
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=YOUR_PASSWORD
# PGDATABASE=rcms
